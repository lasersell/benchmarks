# Pump.fun token mint to benchmark (required)
BENCH_MINT=
# Wallet pubkey, read-only (required)
BENCH_WALLET=

# Private RPC URL (required for PumpFun SDK method)
RPC_URL=
# Jupiter's Metis API key (required for Jupiter method, free at portal.jup.ag)
JUPITER_API_KEY=

# Buy benchmark options
# BENCH_AMOUNT_SOL=0.01
# BENCH_SLIPPAGE_BPS=2000
# BENCH_ITERATIONS=5
# BENCH_WARMUP=1

# Sell benchmark options
# BENCH_AMOUNT_TOKENS=1000000
